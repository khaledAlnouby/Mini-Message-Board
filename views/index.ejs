<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title><%= title %></title>
</head>
<body>
  <h1><%= title %></h1>
  <p><a href="/new">Post a new message</a></p>
  <ul>
    <% messages.forEach(function(m, i){ %>
      <li>
        <strong><%= m.user %></strong>: <%= m.text %> — <em><%= m.added.toLocaleString() %></em>
        <a href="/messages/<%= i %>">Open</a>
      </li>
    <% }) %>
  </ul>
</body>
</html>
